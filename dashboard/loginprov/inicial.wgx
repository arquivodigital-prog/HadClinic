<script>
  /* data/hora */
  (function () {
    const el = document.getElementById('topDate');
    function tick() {
      const now = new Date();
      el.textContent = now.toLocaleString('pt-PT', {
        weekday: 'short', day: '2-digit', month: 'short',
        hour: '2-digit', minute: '2-digit'
      });
    }
    tick(); setInterval(tick, 30000);
  })();

  /* stat consultas */
  document.getElementById('statConsultas').textContent = '6';

  /* pesquisa tabela */
  document.getElementById('docSearch').addEventListener('input', function () {
    const q = this.value.toLowerCase();
    document.querySelectorAll('#docBody tr').forEach(function (row) {
      row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
  });

  /* modal helpers */
  function openModal(title, desc, cb) {
    document.getElementById('modalTitle').textContent = title;
    document.getElementById('modalDesc').textContent  = desc;
    document.getElementById('modalBg').classList.add('open');
    document.getElementById('modalOk').onclick = function () { closeModal(); if (cb) cb(); };
  }
  function closeModal() {
    document.getElementById('modalBg').classList.remove('open');
  }
  document.getElementById('modalBg').addEventListener('click', function (e) {
    if (e.target === this) closeModal();
  });
  window.openModal  = openModal;
  window.closeModal = closeModal;
</script>

</body>
</html>
